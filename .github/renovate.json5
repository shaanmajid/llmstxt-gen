{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":configMigration",
    "helpers:pinGitHubActionDigests",
  ],
  schedule: ["before 9am on the first day of the month"],
  timezone: "America/Los_Angeles",
  labels: ["dependencies"],
  prConcurrentLimit: 3,
  branchConcurrentLimit: 3,
  minimumReleaseAge: "7 days",
  internalChecksFilter: "strict",
  "pre-commit": {
    enabled: true,
  },
  vulnerabilityAlerts: {
    enabled: true,
    schedule: ["at any time"],
    labels: ["security"],
    prCreation: "immediate",
    minimumReleaseAge: null,
  },
  customManagers: [
    {
      // Match version comments in YAML: # renovate: datasource=X depName=Y
      customType: "regex",
      managerFilePatterns: ["/^\\.github/workflows/.*\\.ya?ml$/"],
      matchStrings: [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s*\\n\\s*[\\w-]+:\\s*[\"']?(?<currentValue>[^\"'\\s]+)[\"']?",
      ],
    },
    {
      // Match required-version in pyproject.toml (>=X.Y.Z format)
      customType: "regex",
      managerFilePatterns: ["**/pyproject.toml"],
      matchStrings: [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s*\\nrequired-version\\s*=\\s*[\"']>=(?<currentValue>[\\d.]+)",
      ],
    },
    {
      // Match uv_build upper bound in pyproject.toml (>=X,<=Y format - captures Y)
      customType: "regex",
      managerFilePatterns: ["**/pyproject.toml"],
      matchStrings: [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s*\\nrequires\\s*=\\s*\\[\"[^\"]+<=(?<currentValue>[\\d.]+)",
      ],
    },
  ],
  packageRules: [
    // groupSlug forces shared branches across managers so cross-manager group members consolidate into one PR
    {
      groupName: "GitHub Actions",
      groupSlug: "github-actions",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["minor", "patch"],
    },
    {
      groupName: "ruff",
      groupSlug: "ruff",
      matchPackageNames: ["ruff", "astral-sh/ruff-pre-commit"],
    },
    // uv_build's renovate comment is aliased to depName=uv in pyproject.toml,
    // so uv + uv_build + uv-pre-commit + setup-uv all land in one PR per release
    {
      groupName: "uv",
      groupSlug: "uv",
      matchPackageNames: ["uv", "astral-sh/uv-pre-commit", "astral-sh/setup-uv"],
    },
    {
      groupName: "prek",
      groupSlug: "prek",
      matchPackageNames: ["prek", "j178/prek-action"],
    },
    {
      matchManagers: ["github-actions"],
      addLabels: ["github-actions"],
    },
    {
      matchManagers: ["uv"],
      addLabels: ["python"],
    },
    {
      matchManagers: ["pre-commit"],
      addLabels: ["pre-commit"],
    },
  ],
}
